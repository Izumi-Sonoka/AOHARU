$PKG.Version = "3"

$PKG.Metadata: {
    Version = "3.12.0"
    Description = "Simplified packaging of Python modules (core)"
    Homepage = "https://pypi.org/project/flit-core/"
    Category = "dev-python"
};

$PKG.Depend.BDepends: {
    python3
};

$PKG.Sources: {
    urls = "https://pypi.org/packages/source/f/flit-core/flit_core-3.12.0.tar.gz"
};

$PKG.Checksums: {
    md5:c538415c1f27bd69cbbbf3cdd5135d39 flit_core-3.12.0.tar.gz
};

$PKG.Build: {
    cd flit_core-3.12.0
};

$PKG.Package: {
    cd flit_core-3.12.0
    pip3 install --no-build-isolation \
                 --no-deps \
                 --prefix=/usr \
                 --root="$PKGDIR" \
                 .
};
