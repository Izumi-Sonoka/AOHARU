$PKG.Version = "3"

$PKG.Metadata: {
    Version = "1.85.0"
    Description = "Systems programming language focused on safety, speed, and concurrency"
    Homepage = "https://www.rust-lang.org/"
    Category = "dev-lang"
};

$PKG.Depend.BDepends: {
    gcc
    make
    curl
    python3
    cmake
};

$PKG.Depend.RDepends: {
    glibc
    openssl
    zlib
    libcurl
};

$PKG.Sources: {
    urls = "https://static.rust-lang.org/dist/rustc-1.85.0-src.tar.xz"
};

$PKG.Checksums: {
    sha256:a2d1f5970f7636ffb0e4e9f2a3e93ed96af9fd8b9c6bca0cbf6eb64d7dcf6ad7 rustc-1.85.0-src.tar.xz
};

$PKG.Build: {
    cd rustc-1.85.0-src
    cat > config.toml << EOF
[llvm]
link-shared = true

[build]
target = ["x86_64-unknown-linux-gnu"]
docs = false
extended = true
tools = ["cargo","rustfmt","clippy"]

[install]
prefix = "/usr"
libdir = "lib"
docdir = "share/doc/rust"

[rust]
debuginfo-level = 0
channel = "stable"
rpath = false
EOF
    python3 x.py build --stage 2
};

$PKG.Package: {
    cd rustc-1.85.0-src
    DESTDIR="$PKGDIR" python3 x.py install --stage 2
    # Remove bundled llvm tools to save space
    rm -f "$PKGDIR/usr/lib/libLLVM"*.so
};

$PKG.PostInstall: {
    echo "Rust 1.85.0 installed. Run 'rustup' to manage toolchains, or use 'cargo' directly."
};
