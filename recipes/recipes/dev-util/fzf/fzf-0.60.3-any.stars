$PKG.Version = "3"

$PKG.Metadata: {
    Version = "0.60.3"
    Description = "Command-line fuzzy finder"
    Homepage = "https://github.com/junegunn/fzf"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    go
    make
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://github.com/junegunn/fzf/archive/v0.60.3/fzf-0.60.3.tar.gz"
};

$PKG.Checksums: {
    sha256:bdef337774050c26c6c4a6f38bc4ccb0901450854cd7f667cb3a330166a9ada5 fzf-0.60.3.tar.gz
};

$PKG.Build: {
    cd fzf-0.60.3
    make -j$(nproc) FZF_VERSION=0.60.3 FZF_REVISION=release
};

$PKG.Package: {
    cd fzf-0.60.3
    install -Dm755 target/fzf "$PKGDIR/usr/bin/fzf"
    install -Dm755 bin/fzf-tmux "$PKGDIR/usr/bin/fzf-tmux"
    install -Dm644 man/man1/fzf.1 "$PKGDIR/usr/share/man/man1/fzf.1"
    install -Dm644 man/man1/fzf-tmux.1 "$PKGDIR/usr/share/man/man1/fzf-tmux.1"
    install -Dm644 shell/completion.bash "$PKGDIR/usr/share/fzf/completion.bash"
    install -Dm644 shell/key-bindings.bash "$PKGDIR/usr/share/fzf/key-bindings.bash"
    install -Dm644 shell/completion.zsh "$PKGDIR/usr/share/fzf/completion.zsh"
    install -Dm644 shell/key-bindings.zsh "$PKGDIR/usr/share/fzf/key-bindings.zsh"
    install -Dm644 shell/key-bindings.fish "$PKGDIR/usr/share/fzf/key-bindings.fish"
};
