$PKG.Version = "3"

$PKG.Metadata: {
    Version = "14.1.1"
    Description = "Extremely fast grep that respects .gitignore, written in Rust"
    Homepage = "https://github.com/BurntSushi/ripgrep"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    rust
    cargo
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://github.com/BurntSushi/ripgrep/archive/14.1.1/ripgrep-14.1.1.tar.gz"
};

$PKG.Checksums: {
    sha256:4dad02a2f9c8c3c8d89434e47337aa654cb0e2aa50e806589132f186bf5c2b66 ripgrep-14.1.1.tar.gz
};

$PKG.Build: {
    cd ripgrep-14.1.1
    cargo build --release --locked --features 'pcre2'
};

$PKG.Package: {
    cd ripgrep-14.1.1
    install -Dm755 target/release/rg "$PKGDIR/usr/bin/rg"
    install -Dm644 doc/rg.1 "$PKGDIR/usr/share/man/man1/rg.1"
    install -Dm644 complete/rg.bash "$PKGDIR/usr/share/bash-completion/completions/rg"
    install -Dm644 complete/_rg "$PKGDIR/usr/share/zsh/site-functions/_rg"
    install -Dm644 complete/rg.fish "$PKGDIR/usr/share/fish/vendor_completions.d/rg.fish"
};
