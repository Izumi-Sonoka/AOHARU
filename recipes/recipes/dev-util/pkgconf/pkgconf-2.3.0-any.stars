$PKG.Version = "3"

$PKG.Metadata: {
    Version = "2.3.0"
    Description = "Package compiler and linker metadata toolkit"
    Homepage = "https://gitea.treehouse.systems/ariadne/pkgconf"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    gcc
    make
    meson
    ninja
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://distfiles.ariadne.space/pkgconf/pkgconf-2.3.0.tar.xz"
};

$PKG.Checksums: {
    sha256:3a9080ac51d03615e7c1910a0a2a8df08424892b5f13b0628a204d3fcce0ea8b pkgconf-2.3.0.tar.xz
};

$PKG.Build: {
    cd pkgconf-2.3.0
    ./configure            \
        --prefix=/usr      \
        --disable-static   \
        --docdir=/usr/share/doc/pkgconf-2.3.0
    make -j$(nproc)
};

$PKG.Package: {
    cd pkgconf-2.3.0
    make DESTDIR="$PKGDIR" install
    ln -sfv pkgconf "$PKGDIR"/usr/bin/pkg-config
};
