$PKG.Version = "3"

$PKG.Metadata: {
    Version = "4.9.1"
    Description = "Compiler cache for fast recompilation"
    Homepage = "https://ccache.dev/"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    gcc
    cmake
    make
    zlib
    zstd
};

$PKG.Depend.RDepends: {
    glibc
    zlib
    zstd
};

$PKG.Sources: {
    urls = "https://github.com/ccache/ccache/releases/download/v4.9.1/ccache-4.9.1.tar.xz"
};

$PKG.Checksums: {
    sha256:4c03bc840699127d16c3f0e6112e3f40ce6a230d5873daa78c60a59c7ef59d25 ccache-4.9.1.tar.xz
};

$PKG.Build: {
    cd ccache-4.9.1
    cmake -B build                        \
        -DCMAKE_BUILD_TYPE=Release        \
        -DCMAKE_INSTALL_PREFIX=/usr       \
        -DCMAKE_INSTALL_SYSCONFDIR=/etc   \
        -DENABLE_TESTING=OFF              \
        -DREDIS_STORAGE_BACKEND=OFF
    cmake --build build -j$(nproc)
};

$PKG.Package: {
    cd ccache-4.9.1
    DESTDIR="$PKGDIR" cmake --install build
    mkdir -p "$PKGDIR"/usr/lib/ccache/bin
    for compiler in gcc g++ cc c++ clang clang++; do
        ln -sf /usr/bin/ccache "$PKGDIR"/usr/lib/ccache/bin/$compiler
    done
    mkdir -p "$PKGDIR"/etc/ccache
    cat > "$PKGDIR"/etc/ccache/ccache.conf <<'EOF'
max_size = 5.0G
compression = true
compression_level = 6
EOF
};

$PKG.PostInstall: {
    cat <<MSG
ccache installed. To enable, add to /etc/astral/make.conf:
    CCACHE_ENABLED="yes"
MSG
};
