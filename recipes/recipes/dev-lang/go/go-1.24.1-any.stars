$PKG.Version = "3"

$PKG.Metadata: {
    Version = "1.24.1"
    Description = "Open source programming language focused on simplicity and efficiency"
    Homepage = "https://go.dev/"
    Category = "dev-lang"
};

$PKG.Depend.BDepends: {
    gcc
    make
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://go.dev/dl/go1.24.1.linux-amd64.tar.gz"
};

$PKG.Checksums: {
    sha256:cb2396bae64183cdccf81a9a6df0aea3bce9511fc21469fb89a0c00470088073 go1.24.1.linux-amd64.tar.gz
};

$PKG.Build: {
    # Go ships pre-compiled; nothing to build
    true
};

$PKG.Package: {
    mkdir -p "$PKGDIR/usr/local"
    cp -a go "$PKGDIR/usr/local/go"
    mkdir -p "$PKGDIR/usr/bin"
    ln -sf /usr/local/go/bin/go "$PKGDIR/usr/bin/go"
    ln -sf /usr/local/go/bin/gofmt "$PKGDIR/usr/bin/gofmt"
};

$PKG.PostInstall: {
    echo "Go 1.24.1 installed to /usr/local/go"
    echo "Add export GOPATH=\$HOME/go to your shell profile if needed."
};
