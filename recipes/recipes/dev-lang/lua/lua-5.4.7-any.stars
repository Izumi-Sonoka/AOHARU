$PKG.Version = "3"

$PKG.Metadata: {
    Version = "5.4.7"
    Description = "Powerful, fast, lightweight, embeddable scripting language"
    Homepage = "https://www.lua.org/"
    Category = "dev-lang"
};

$PKG.Depend.BDepends: {
    gcc
    make
};

$PKG.Depend.RDepends: {
    glibc
    readline
};

$PKG.Sources: {
    urls = "https://www.lua.org/ftp/lua-5.4.7.tar.gz"
};

$PKG.Checksums: {
    sha256:9fbf5e28ef86c69858f6d3d34eccc32e911c1a28b4120ff3e84aaa70cfbf1e30 lua-5.4.7.tar.gz
};

$PKG.Build: {
    cd lua-5.4.7
    make -j$(nproc) MYCFLAGS="$CFLAGS -fPIC" linux-readline
};

$PKG.Package: {
    cd lua-5.4.7
    make DESTDIR="$PKGDIR" INSTALL_TOP=/usr install
    install -Dm644 doc/lua.1 "$PKGDIR/usr/share/man/man1/lua.1"
    install -Dm644 doc/luac.1 "$PKGDIR/usr/share/man/man1/luac.1"
};
