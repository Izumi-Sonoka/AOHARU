$PKG.Version = "3"

$PKG.Metadata: {
    Version = "3.31.6"
    Description = "Cross-platform build system generator"
    Homepage = "https://cmake.org/"
    Category = "sys-devel"
};

$PKG.Depend.BDepends: {
    gcc
    make
    openssl
    curl
    zlib
    libarchive
};

$PKG.Depend.RDepends: {
    glibc
    openssl
    curl
    zlib
    libarchive
};

$PKG.Sources: {
    urls = "https://cmake.org/files/v3.31/cmake-3.31.6.tar.gz"
};

$PKG.Checksums: {
    sha256:653427f0f5014750aafff22727fb2aa60c6c732ca91808cfb78ce22ddd9e55f0 cmake-3.31.6.tar.gz
};

$PKG.Build: {
    cd cmake-3.31.6
    ./bootstrap          \
        --prefix=/usr    \
        --system-libs    \
        --mandir=/share/man \
        --no-system-jsoncpp \
        --no-system-librhash \
        --docdir=/share/doc/cmake-3.31.6
    make -j$(nproc)
};

$PKG.Package: {
    cd cmake-3.31.6
    make DESTDIR="$PKGDIR" install
};
