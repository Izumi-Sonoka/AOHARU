$PKG.Version = "3"

$PKG.Metadata: {
    Version     = "2.3.0"
    Description = "Package compiler and linker metadata toolkit"
    Homepage    = "https://github.com/pkgconf/pkgconf"
    Category    = "dev-util"
};

$PKG.Depend.BDepends: {
    meson
    ninja
};

$PKG.Sources: {
    urls = "https://distfiles.ariadne.space/pkgconf/pkgconf-2.3.0.tar.xz"
};

$PKG.Checksums: {
    sha256:3a9080ac51d03615e7c1910a0a2a8df08424892b5f13b0628a204d3fcce0ea8b pkgconf-2.3.0.tar.xz
};

$PKG.Build: {
    cd pkgconf-2.3.0
    meson setup build --prefix=/usr \
        -Dc_args="$CFLAGS" \
        -Dcpp_args="$CXXFLAGS" \
        -Dc_link_args="$LDFLAGS"
    ninja -C build
};

$PKG.Package: {
    cd pkgconf-2.3.0
    DESTDIR="$PKGDIR" ninja -C build install
    ln -sf pkgconf "$PKGDIR/usr/bin/pkg-config"
};
