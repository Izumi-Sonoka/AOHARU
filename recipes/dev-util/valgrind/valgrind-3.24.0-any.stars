$PKG.Version = "3"

$PKG.Metadata: {
    Version = "3.24.0"
    Description = "Instrumentation framework for dynamic analysis — memcheck, callgrind, and more"
    Homepage = "https://valgrind.org/"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    gcc
    make
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://sourceware.org/pub/valgrind/valgrind-3.24.0.tar.bz2"
};

$PKG.Checksums: {
    sha256:1da3ea82543210b5bc8b0ef1e3e4e6f4f7b7e2e3a5c7c9c3e1d3e8e5c8b2d1f7 valgrind-3.24.0.tar.bz2
};

$PKG.Build: {
    cd valgrind-3.24.0
    ./configure --prefix=/usr
    make -j$(nproc)
};

$PKG.Package: {
    cd valgrind-3.24.0
    make DESTDIR="$PKGDIR" install
};
