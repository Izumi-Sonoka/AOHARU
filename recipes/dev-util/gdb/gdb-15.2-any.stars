$PKG.Version = "3"

$PKG.Metadata: {
    Version = "15.2"
    Description = "GNU Debugger — the standard debugger for the GNU software system"
    Homepage = "https://www.gnu.org/software/gdb/"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    gcc
    make
    python3
    texinfo
};

$PKG.Depend.RDepends: {
    glibc
    readline
    ncurses
    expat
    python3
    zlib
    mpfr
};

$PKG.Sources: {
    urls = "https://ftp.gnu.org/gnu/gdb/gdb-15.2.tar.xz"
};

$PKG.Checksums: {
    sha256:a1d5f10b45fc59867a9c5c21ca7e77c2a7e7c76f52b62db9b6f05dd27b38ad67 gdb-15.2.tar.xz
};

$PKG.Build: {
    cd gdb-15.2
    mkdir build && cd build
    ../configure \
        --prefix=/usr \
        --with-system-readline \
        --with-python=/usr/bin/python3 \
        --with-expat \
        --enable-tui
    make -j$(nproc)
};

$PKG.Package: {
    cd gdb-15.2/build
    make DESTDIR="$PKGDIR" install
    # Remove duplication with binutils
    rm -f "$PKGDIR/usr/include/"{ansidecl,bfd,bfdlink,ctf,ctf-api,diagnostics,dis-asm,symcat}.h
};
