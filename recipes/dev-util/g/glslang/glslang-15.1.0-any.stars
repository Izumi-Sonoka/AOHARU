# NOTE: Replace PLACEHOLDER checksums by running:
#   astral-recipegen checksum <url> sha256

$PKG.Version = "3"

$PKG.Metadata: {
    Version     = "15.1.0"
    Description = "OpenGL / OpenGL ES Reference Compiler"
    Homepage    = "https://github.com/KhronosGroup/glslang"
    Category    = "dev-util"
};

$PKG.Depend.BDepends: {
    cmake
    ninja
    python3
};

$PKG.Sources: {
    urls = "https://github.com/KhronosGroup/glslang/archive/refs/tags/15.1.0.tar.gz"
};

$PKG.Checksums: {
    sha256:4bdcd8cdb330313f0d4deed7be527b0ac1c115ff272e492853a6e98add61b4bc 15.1.0.tar.gz
};

$PKG.Build: {
    cd glslang-15.1.0
    cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_SHARED_LIBS=ON
    cmake --build build
};

$PKG.Package: {
    cd glslang-15.1.0
    DESTDIR="$PKGDIR" cmake --install build
};
