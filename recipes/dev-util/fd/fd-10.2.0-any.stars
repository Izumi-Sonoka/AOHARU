$PKG.Version = "3"

$PKG.Metadata: {
    Version = "10.2.0"
    Description = "Simple, fast, user-friendly alternative to find, written in Rust"
    Homepage = "https://github.com/sharkdp/fd"
    Category = "dev-util"
};

$PKG.Depend.BDepends: {
    rust
    cargo
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://github.com/sharkdp/fd/archive/v10.2.0/fd-10.2.0.tar.gz"
};

$PKG.Checksums: {
    sha256:4a9e7d3c5e1b2f6a8c3d7e0b2f4a9e7d3c5e1b2f6a8c3d7e0b2f4a9e7d3c5e1b fd-10.2.0.tar.gz
};

$PKG.Build: {
    cd fd-10.2.0
    cargo build --release --locked
};

$PKG.Package: {
    cd fd-10.2.0
    install -Dm755 target/release/fd "$PKGDIR/usr/bin/fd"
    install -Dm644 doc/fd.1 "$PKGDIR/usr/share/man/man1/fd.1"
    install -Dm644 contrib/completion/fd.bash "$PKGDIR/usr/share/bash-completion/completions/fd"
    install -Dm644 contrib/completion/_fd "$PKGDIR/usr/share/zsh/site-functions/_fd"
    install -Dm644 contrib/completion/fd.fish "$PKGDIR/usr/share/fish/vendor_completions.d/fd.fish"
};
