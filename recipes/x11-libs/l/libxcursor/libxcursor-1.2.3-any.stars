$PKG.Version = "3"

$PKG.Metadata: {
    Version     = "1.2.3"
    Description = "X cursor management library"
    Homepage    = "https://xorg.freedesktop.org"
    Category    = "x11-libs"
};

$PKG.Depend.BDepends: {
    autoconf
    automake
    pkg-config
};

$PKG.Depend.RDepends: {
    libxrender
    libxfixes
    libx11
};

$PKG.Sources: {
    urls = "https://xorg.freedesktop.org/archive/individual/lib/libXcursor-1.2.3.tar.xz"
};

$PKG.Checksums: {
    sha256:fde9402dd4cfe79da71e2d96bb980afc5e6ff4f8a7d74c159e1966afb2b2c2c0 libXcursor-1.2.3.tar.xz
};

$PKG.Build: {
    cd libXcursor-1.2.3
    ./configure --prefix=/usr
    make -j${JOBS:-$(nproc)}
};

$PKG.Package: {
    cd libXcursor-1.2.3
    make DESTDIR="$PKGDIR" install
};
