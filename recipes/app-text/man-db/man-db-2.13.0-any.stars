$PKG.Version = "3"

$PKG.Metadata: {
    Version = "2.13.0"
    Description = "The man-db manual pager suite"
    Homepage = "https://www.nongnu.org/man-db/"
    Category = "app-text"
};

$PKG.Depend.BDepends: {
    gcc
    make
    pkgconf
};

$PKG.Depend.RDepends: {
    glibc
    gdbm
    libpipeline
    groff
    zlib
};

$PKG.Sources: {
    urls = "https://download.savannah.gnu.org/releases/man-db/man-db-2.13.0.tar.xz"
};

$PKG.Checksums: {
    sha256:b78d9d7b7f7e8fc2b2c51d0fc7f93f765ffd8d8c784c77b4c1e4ab8cd88745c4 man-db-2.13.0.tar.xz
};

$PKG.Build: {
    cd man-db-2.13.0
    ./configure \
        --prefix=/usr \
        --docdir=/usr/share/doc/man-db-2.13.0 \
        --sysconfdir=/etc \
        --disable-setuid \
        --with-browser=/usr/bin/lynx \
        --with-vgrind=/usr/bin/vgrind \
        --with-grap=/usr/bin/grap
    make -j$(nproc)
};

$PKG.Package: {
    cd man-db-2.13.0
    make DESTDIR="$PKGDIR" install
};
