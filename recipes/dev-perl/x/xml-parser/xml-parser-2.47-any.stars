$PKG.Version = "3"

$PKG.Metadata: {
    Version = "2.47"
    Description = "Perl XML::Parser module"
    Homepage = "https://metacpan.org/pod/XML::Parser"
    Category = "dev-perl"
};

$PKG.Depend.BDepends: {
    gcc
    make
    perl
    expat
};

$PKG.Sources: {
    urls = "https://cpan.metacpan.org/authors/id/T/TO/TODDR/XML-Parser-2.47.tar.gz"
};

$PKG.Checksums: {
    md5:89a8e82cfd2ad948b349c0a69c494463 XML-Parser-2.47.tar.gz
};

$PKG.Build: {
    cd XML-Parser-2.47
    perl Makefile.PL
    make -j${JOBS:-$(nproc)}
};

$PKG.Package: {
    cd XML-Parser-2.47
    make DESTDIR="$PKGDIR" install
};
