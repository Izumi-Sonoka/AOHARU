$PKG.Version = "3"

$PKG.Metadata: {
    Version = "2.6.4"
    Description = "XML parsing library"
    Homepage = "https://libexpat.github.io/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://github.com/libexpat/libexpat/releases/download/R_2_6_4/expat-2.6.4.tar.xz"
};

$PKG.Checksums: {
    sha256:a695629dae047055b37d50a0ff4776d1d45d0a4c842cf4ccee158441f55ff7ee expat-2.6.4.tar.xz
};

$PKG.Build: {
    cd expat-2.6.4
    ./configure            \
        --prefix=/usr      \
        --disable-static   \
        --docdir=/usr/share/doc/expat-2.6.4
    make -j$(nproc)
};

$PKG.Package: {
    cd expat-2.6.4
    make DESTDIR="$PKGDIR" install
};
