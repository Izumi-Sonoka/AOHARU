$PKG.Version = "3"

$PKG.Metadata: {
    Version = "3.4.6"
    Description = "Foreign Function Interface library"
    Homepage = "https://sourceware.org/libffi/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
};

$PKG.Depend.RDepends: {
    glibc
};

$PKG.Sources: {
    urls = "https://github.com/libffi/libffi/releases/download/v3.4.6/libffi-3.4.6.tar.gz"
};

$PKG.Checksums: {
    sha256:b0dea9df23c863a7a50e825440f3ebffabd65df1497108e5d437747843895ef4 libffi-3.4.6.tar.gz
};

$PKG.Build: {
    cd libffi-3.4.6
    ./configure            \
        --prefix=/usr      \
        --disable-static   \
        --with-gcc-arch=native
    make -j$(nproc)
};

$PKG.Package: {
    cd libffi-3.4.6
    make DESTDIR="$PKGDIR" install
};
