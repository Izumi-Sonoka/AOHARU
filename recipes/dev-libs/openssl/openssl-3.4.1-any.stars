$PKG.Version = "3"

$PKG.Metadata: {
    Version = "3.4.1"
    Description = "Toolkit for Transport Layer Security and general cryptography"
    Homepage = "https://openssl.org/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
    perl
    zlib
};

$PKG.Depend.RDepends: {
    glibc
    zlib
};

$PKG.Sources: {
    urls = "https://github.com/openssl/openssl/releases/download/openssl-3.4.1/openssl-3.4.1.tar.gz"
};

$PKG.Checksums: {
    sha256:002a2d63310e761d8f83080af7b8de5c8c097a63a0de1b8a28e8fcbef0c49e23 openssl-3.4.1.tar.gz
};

$PKG.Build: {
    cd openssl-3.4.1
    ./config               \
        --prefix=/usr      \
        --openssldir=/etc/ssl \
        --libdir=lib       \
        shared             \
        zlib-dynamic
    make -j$(nproc)
};

$PKG.Package: {
    cd openssl-3.4.1
    sed -i '/INSTALL_LIBS/s/libcrypto.a libssl.a//' Makefile
    make DESTDIR="$PKGDIR" install
};
