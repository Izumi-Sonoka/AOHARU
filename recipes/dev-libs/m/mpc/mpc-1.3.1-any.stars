$PKG.Version = "3"

$PKG.Metadata: {
    Version = "1.3.1"
    Description = "GNU multiple precision complex arithmetic library"
    Homepage = "https://www.multiprecision.org/mpc/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
};

$PKG.Depend.RDepends: {
    gmp
    mpfr
};

$PKG.Sources: {
    urls = "https://ftp.gnu.org/gnu/mpc/mpc-1.3.1.tar.gz"
};

$PKG.Checksums: {
    md5:5c9bc658c9fd0f940e8e3e0f09530c62 mpc-1.3.1.tar.gz
};

$PKG.Build: {
    cd mpc-1.3.1
    ./configure --prefix=/usr \
                --disable-static \
                --docdir=/usr/share/doc/mpc-1.3.1
    make -j${JOBS:-$(nproc)}
    make html
};

$PKG.Package: {
    cd mpc-1.3.1
    make DESTDIR="$PKGDIR" install
    make DESTDIR="$PKGDIR" install-html
};
