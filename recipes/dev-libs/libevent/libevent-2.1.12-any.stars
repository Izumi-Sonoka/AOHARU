$PKG.Version = "3"

$PKG.Metadata: {
    Version = "2.1.12"
    Description = "Event notification library used by tmux, tor, and others"
    Homepage = "https://libevent.org/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
    pkgconf
};

$PKG.Depend.RDepends: {
    glibc
    openssl
};

$PKG.Sources: {
    urls = "https://github.com/libevent/libevent/releases/download/release-2.1.12-stable/libevent-2.1.12-stable.tar.gz"
};

$PKG.Checksums: {
    sha256:92e6de1be9ec176428fd2367677e61ceffc2ee1cb119035037a27d346b0403bb libevent-2.1.12-stable.tar.gz
};

$PKG.Build: {
    cd libevent-2.1.12-stable
    ./configure \
        --prefix=/usr \
        --disable-static \
        --disable-libevent-regress
    make -j$(nproc)
};

$PKG.Package: {
    cd libevent-2.1.12-stable
    make DESTDIR="$PKGDIR" install
};
