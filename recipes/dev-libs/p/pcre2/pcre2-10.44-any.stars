$PKG.Version = "3"

$PKG.Metadata: {
    Version = "10.44"
    Description = "Perl-compatible regular expression library, version 2"
    Homepage = "https://www.pcre.org/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
    pkgconf
};

$PKG.Depend.RDepends: {
    glibc
    zlib
    bzip2
};

$PKG.Sources: {
    urls = "https://github.com/PCRE2Project/pcre2/releases/download/pcre2-10.44/pcre2-10.44.tar.bz2"
};

$PKG.Checksums: {
    sha256:d34f02e113cf7193a1ebf2770d3ac527088d485d4e047ed10e5d217c6ef5de96 pcre2-10.44.tar.bz2
};

$PKG.Build: {
    cd pcre2-10.44
    ./configure \
        --prefix=/usr \
        --enable-unicode \
        --enable-jit \
        --enable-pcre2-16 \
        --enable-pcre2-32 \
        --enable-pcre2grep-libz \
        --enable-pcre2grep-libbz2 \
        --disable-static
    make -j${JOBS:-$(nproc)}
};

$PKG.Package: {
    cd pcre2-10.44
    make DESTDIR="$PKGDIR" install
};
