$PKG.Version = "3"

$PKG.Metadata: {
    Version = "2.84.0"
    Description = "Core application building blocks for GNOME and other libraries"
    Homepage = "https://wiki.gnome.org/Projects/GLib"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    meson
    ninja
    pkgconf
    python3
};

$PKG.Depend.RDepends: {
    glibc
    pcre2
    zlib
    libffi
    util-linux
};

$PKG.Sources: {
    urls = "https://download.gnome.org/sources/glib/2.84/glib-2.84.0.tar.xz"
};

$PKG.Checksums: {
    sha256:f8823600cb85425e2815cfad82ea20fdaa538482ab74e7293d58b3f64a5aff6a glib-2.84.0.tar.xz
};

$PKG.Build: {
    cd glib-2.84.0
    mkdir build && cd build
    meson setup .. \ \
        -Dc_args="$CFLAGS" \
        -Dcpp_args="$CXXFLAGS" \
        -Dc_link_args="$LDFLAGS"
        --prefix=/usr \
        --buildtype=release \
        -Dman-pages=disabled \
        -Dtests=false \
        -Dintrospection=disabled
    ninja -j${JOBS:-$(nproc)}
};

$PKG.Package: {
    cd glib-2.84.0/build
    DESTDIR="$PKGDIR" ninja install
};
