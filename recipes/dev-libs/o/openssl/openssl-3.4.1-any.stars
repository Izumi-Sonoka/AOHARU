$PKG.Version = "3"

$PKG.Metadata: {
    Version = "3.4.1"
    Description = "Toolkit for Transport Layer Security and general cryptography"
    Homepage = "https://openssl.org/"
    Category = "dev-libs"
};

$PKG.Depend.BDepends: {
    gcc
    make
    perl
    zlib
};

$PKG.Depend.RDepends: {
    glibc
    zlib
};

$PKG.Sources: {
    urls = "https://github.com/openssl/openssl/releases/download/openssl-3.4.1/openssl-3.4.1.tar.gz"
};

$PKG.Checksums: {
    sha256:002a2d6b30b58bf4bea46c43bdd96365aaf8daa6c428782aa4feee06da197df3 openssl-3.4.1.tar.gz
};

$PKG.Build: {
    cd openssl-3.4.1
    ./config               \
        --prefix=/usr      \
        --openssldir=/etc/ssl \
        --libdir=lib       \
        shared             \
        zlib-dynamic
    make -j${JOBS:-$(nproc)}
};

$PKG.Package: {
    cd openssl-3.4.1
    sed -i '/INSTALL_LIBS/s/libcrypto.a libssl.a//' Makefile
    make DESTDIR="$PKGDIR" install
};
