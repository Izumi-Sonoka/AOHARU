$PKG.Version = "3"

$PKG.Metadata: {
    Version = "8.12.1"
    Description = "Command line tool and library for transferring data with URLs"
    Homepage = "https://curl.se/"
    Category = "net-misc"
};

$PKG.Depend.BDepends: {
    gcc
    make
    openssl
    zlib
    pkg-config
};

$PKG.Depend.RDepends: {
    glibc
    openssl
    zlib
};

$PKG.Depend.Optional: {
    nghttp2
    libssh2
    libidn2
};

$PKG.Sources: {
    urls = "https://curl.se/download/curl-8.12.1.tar.xz"
};

$PKG.Checksums: {
    sha256:0341f1ed97a26c811abaebd37d62b833956792b7607ea3f15d001613c76de202 curl-8.12.1.tar.xz
};

$PKG.Build: {
    cd curl-8.12.1
    ./configure              \
        --prefix=/usr        \
        --disable-static     \
        --with-openssl       \
        --enable-threaded-resolver \
        --with-ca-bundle=/etc/ssl/certs/ca-certificates.crt
    make -j${JOBS:-$(nproc)}
};

$PKG.Package: {
    cd curl-8.12.1
    make DESTDIR="$PKGDIR" install
};
